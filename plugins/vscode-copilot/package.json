{
  "name": "tinyai-observability-copilot",
  "displayName": "TinyAI Observability",
  "description": "Native VS Code extension for Copilot-era TinyAI coding telemetry.",
  "version": "0.1.8",
  "publisher": "tinyai",
  "private": true,
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onView:tinyaiObservability.actionsView",
    "onCommand:tinyaiObservability.openPanel",
    "onCommand:tinyaiObservability.showMenu",
    "onCommand:tinyaiObservability.captureCopilotLocalTranscripts",
    "onCommand:tinyaiObservability.captureActiveEditorConversation",
    "onCommand:tinyaiObservability.captureClipboardConversation",
    "onCommand:tinyaiObservability.recordAiLinesSnapshot",
    "onCommand:tinyaiObservability.recordCommitSnapshot",
    "onCommand:tinyaiObservability.recordPushSnapshot",
    "onCommand:tinyaiObservability.installGitHooks"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tinyaiObservability",
          "title": "TinyAI",
          "icon": "media/tinyai.svg"
        }
      ]
    },
    "views": {
      "tinyaiObservability": [
        {
          "id": "tinyaiObservability.actionsView",
          "name": "Observability",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "TinyAI Observability",
      "properties": {
        "tinyaiObservability.collectorUrl": {
          "type": "string",
          "default": "http://localhost:18080",
          "description": "TinyAI observability collector URL."
        },
        "tinyaiObservability.token": {
          "type": "string",
          "default": "dev-token",
          "description": "Collector bearer token."
        },
        "tinyaiObservability.captureConversationText": {
          "type": "boolean",
          "default": true,
          "description": "Capture full conversation text for TinyAI-owned chat surfaces and imported Copilot transcripts."
        },
        "tinyaiObservability.autoCaptureCopilotLocalTranscripts": {
          "type": "boolean",
          "default": true,
          "description": "Automatically capture local GitHub Copilot Chat transcript JSONL files from VS Code workspaceStorage."
        }
      }
    },
    "chatParticipants": [
      {
        "id": "tinyai.tinyai-observability-copilot.tinyai",
        "name": "tinyai",
        "fullName": "TinyAI",
        "description": "Use personal specs and capture coding telemetry",
        "isSticky": true,
        "disambiguation": [
          {
            "category": "TinyAI personal specs coding",
            "description": "Requests that should read TinyAI or OpenSpec personal specs before coding, compare personal specs with official specs, or capture AI coding telemetry.",
            "examples": [
              "按个人 specs 修改订单状态逻辑",
              "先读取个人知识库再修复这个 bug",
              "根据 openspec 里的 workspace spec 实现这个需求",
              "对比 official 和 personal spec 后改代码",
              "按项目知识库规则完成这个任务"
            ]
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "tinyai_specs",
        "tags": ["tinyai", "specs", "observability"],
        "toolReferenceName": "tinyai_specs",
        "displayName": "TinyAI Specs",
        "modelDescription": "Search TinyAI/OpenSpec personal specs and catalog for relevant project rules. Use this before coding when the user mentions personal specs, specs, OpenSpec, project knowledge, catalog, workspace rules, official-vs-personal spec differences, or domain logic that may be documented in the knowledge base. The tool also records direct specs telemetry for observability.",
        "userDescription": "Search TinyAI personal specs and record specs telemetry.",
        "canBeReferencedInPrompt": true,
        "icon": "$(book)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "The user's coding or analysis request to search in TinyAI/OpenSpec specs."
            }
          },
          "required": ["query"]
        }
      }
    ],
    "commands": [
      {
        "command": "tinyaiObservability.configure",
        "title": "TinyAI Observability: Configure"
      },
      {
        "command": "tinyaiObservability.openPanel",
        "title": "TinyAI Observability: Open Panel"
      },
      {
        "command": "tinyaiObservability.showMenu",
        "title": "TinyAI Observability: Show Menu"
      },
      {
        "command": "tinyaiObservability.openDashboard",
        "title": "TinyAI Observability: Open Dashboard"
      },
      {
        "command": "tinyaiObservability.startTask",
        "title": "TinyAI Observability: Start Task"
      },
      {
        "command": "tinyaiObservability.endTask",
        "title": "TinyAI Observability: End Task"
      },
      {
        "command": "tinyaiObservability.flushEvents",
        "title": "TinyAI Observability: Flush Events"
      },
      {
        "command": "tinyaiObservability.captureClipboardConversation",
        "title": "TinyAI Observability: Capture Clipboard Conversation"
      },
      {
        "command": "tinyaiObservability.captureActiveEditorConversation",
        "title": "TinyAI Observability: Capture Active Editor Conversation"
      },
      {
        "command": "tinyaiObservability.captureCopilotLocalTranscripts",
        "title": "TinyAI Observability: Capture Copilot Local Transcripts"
      },
      {
        "command": "tinyaiObservability.recordAiLinesSnapshot",
        "title": "TinyAI Observability: Record AI Lines Snapshot"
      },
      {
        "command": "tinyaiObservability.recordCommitSnapshot",
        "title": "TinyAI Observability: Record Commit Snapshot"
      },
      {
        "command": "tinyaiObservability.recordPushSnapshot",
        "title": "TinyAI Observability: Record Push/PR Snapshot"
      },
      {
        "command": "tinyaiObservability.installGitHooks",
        "title": "TinyAI Observability: Install Git Hooks"
      },
      {
        "command": "tinyaiObservability.recordFeedback",
        "title": "TinyAI Observability: Record Feedback"
      },
      {
        "command": "tinyaiObservability.adoptionSnapshot",
        "title": "TinyAI Observability: Record Adoption Snapshot"
      },
      {
        "command": "tinyaiObservability.showCurrentTask",
        "title": "TinyAI Observability: Show Current Task"
      }
    ]
  },
  "scripts": {
    "compile": "npm run typecheck && node esbuild.mjs",
    "typecheck": "tsc -p ./ --noEmit",
    "package": "npm run compile && npx vsce package --allow-missing-repository"
  },
  "dependencies": {},
  "devDependencies": {
    "@tinyai/observability-runtime": "file:../../plugin-runtime",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.2"
  }
}
