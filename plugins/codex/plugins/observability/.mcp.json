{
  "mcpServers": {
    "tinyai-observability": {
      "command": "node",
      "args": ["runtime/dist/mcp-server.js"],
      "env": {
        "TINYAI_OBS_TOOL": "codex",
        "TINYAI_OBS_ENV_FILE": "${TINYAI_OBS_ENV_FILE}",
        "TINYAI_OBS_COLLECTOR_URL": "${TINYAI_OBS_COLLECTOR_URL}",
        "TINYAI_OBS_COLLECTOR_URLS": "${TINYAI_OBS_COLLECTOR_URLS}",
        "TINYAI_OBS_TOKEN": "${TINYAI_OBS_TOKEN}",
        "TINYAI_OBS_USER_NAME": "${TINYAI_OBS_USER_NAME}",
        "TINYAI_OBS_USER_EMAIL": "${TINYAI_OBS_USER_EMAIL}",
        "TINYAI_OBS_USER_ID": "${TINYAI_OBS_USER_ID}",
        "TINYAI_OBS_CODEX_USER_NAME": "${TINYAI_OBS_CODEX_USER_NAME}",
        "TINYAI_OBS_CODEX_USER_DISPLAY_NAME": "${TINYAI_OBS_CODEX_USER_DISPLAY_NAME}",
        "TINYAI_OBS_CODEX_USERNAME": "${TINYAI_OBS_CODEX_USERNAME}",
        "TINYAI_OBS_CODEX_USER_EMAIL": "${TINYAI_OBS_CODEX_USER_EMAIL}",
        "TINYAI_OBS_CODEX_USER_ID": "${TINYAI_OBS_CODEX_USER_ID}",
        "TINYAI_OBS_TEAM": "${TINYAI_OBS_TEAM}",
        "TINYAI_OBS_PLUGIN_VERSION": "0.1.5+codex.20260630213400",
        "TINYAI_OBS_CAPTURE_CONVERSATION_TEXT": "true",
        "TINYAI_OBS_AUTO_CAPTURE_CONVERSATION": "true"
      }
    }
  }
}
