{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "TINYAI_OBS_ENV_FILE=\"${TINYAI_OBS_ENV_FILE:-$HOME/.tinyai-observability/tinyai-observability.env}\"; [ -f \"$TINYAI_OBS_ENV_FILE\" ] && . \"$TINYAI_OBS_ENV_FILE\"; TINYAI_OBS_TOOL=claude TINYAI_OBS_EVENT_TYPE=task_start TINYAI_OBS_PLUGIN_VERSION=0.1.5 TINYAI_OBS_CAPTURE_CONVERSATION_TEXT=true node \"${CLAUDE_PLUGIN_ROOT}/runtime/dist/hook.js\"",
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "TINYAI_OBS_ENV_FILE=\"${TINYAI_OBS_ENV_FILE:-$HOME/.tinyai-observability/tinyai-observability.env}\"; [ -f \"$TINYAI_OBS_ENV_FILE\" ] && . \"$TINYAI_OBS_ENV_FILE\"; TINYAI_OBS_TOOL=claude TINYAI_OBS_EVENT_TYPE=bash_pre_tool_use TINYAI_OBS_PLUGIN_VERSION=0.1.5 node \"${CLAUDE_PLUGIN_ROOT}/runtime/dist/hook.js\"",
            "async": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "TINYAI_OBS_ENV_FILE=\"${TINYAI_OBS_ENV_FILE:-$HOME/.tinyai-observability/tinyai-observability.env}\"; [ -f \"$TINYAI_OBS_ENV_FILE\" ] && . \"$TINYAI_OBS_ENV_FILE\"; TINYAI_OBS_TOOL=claude TINYAI_OBS_EVENT_TYPE=bash_post_tool_use TINYAI_OBS_PLUGIN_VERSION=0.1.5 node \"${CLAUDE_PLUGIN_ROOT}/runtime/dist/hook.js\"",
            "async": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "TINYAI_OBS_ENV_FILE=\"${TINYAI_OBS_ENV_FILE:-$HOME/.tinyai-observability/tinyai-observability.env}\"; [ -f \"$TINYAI_OBS_ENV_FILE\" ] && . \"$TINYAI_OBS_ENV_FILE\"; TINYAI_OBS_TOOL=claude TINYAI_OBS_EVENT_TYPE=turn_snapshot TINYAI_OBS_PLUGIN_VERSION=0.1.5 TINYAI_OBS_CAPTURE_CONVERSATION_TEXT=true TINYAI_OBS_OUTPUT_TOKENS=\"${CLAUDE_CODE_OUTPUT_TOKENS:-}\" node \"${CLAUDE_PLUGIN_ROOT}/runtime/dist/hook.js\"",
            "async": false
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "TINYAI_OBS_ENV_FILE=\"${TINYAI_OBS_ENV_FILE:-$HOME/.tinyai-observability/tinyai-observability.env}\"; [ -f \"$TINYAI_OBS_ENV_FILE\" ] && . \"$TINYAI_OBS_ENV_FILE\"; TINYAI_OBS_TOOL=claude TINYAI_OBS_EVENT_TYPE=turn_snapshot TINYAI_OBS_PLUGIN_VERSION=0.1.5 TINYAI_OBS_CAPTURE_CONVERSATION_TEXT=true TINYAI_OBS_OUTPUT_TOKENS=\"${CLAUDE_CODE_OUTPUT_TOKENS:-}\" node \"${CLAUDE_PLUGIN_ROOT}/runtime/dist/hook.js\"",
            "async": false
          }
        ]
      }
    ]
  }
}
