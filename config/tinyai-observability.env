# TinyAI Observability shared runtime config.
#
# Runtime priority:
# 1. Existing process environment
# 2. This env file, when copied to ~/.tinyai-observability/tinyai-observability.env
# 3. Built-in defaults
#
# Collector upload behavior:
# - TINYAI_OBS_COLLECTOR_URL is tried first.
# - TINYAI_OBS_COLLECTOR_URLS are fallbacks, tried only if the previous URL fails.
# - A successful upload stops the retry chain, so multiple reachable URLs do not create multiple writes.
# - Copilot, Claude, and Codex share these addresses only as defaults.
# - Their local queues, tool names, plugin versions, and source parsing stay isolated by tool.

TINYAI_OBS_COLLECTOR_URL=http://10.161.248.133:18080
TINYAI_OBS_COLLECTOR_URLS=

TINYAI_OBS_DASHBOARD_URL=http://10.161.248.133:18081
TINYAI_OBS_DASHBOARD_URLS=

TINYAI_OBS_CAPTURE_CONVERSATION_TEXT=true
TINYAI_OBS_CAPTURE_VISIBLE_REASONING_TEXT=true
TINYAI_OBS_AUTO_CAPTURE_CONVERSATION=true

# Git hook is repository-level, not owned by Copilot/Claude/Codex.
# Keep it stable so whichever plugin installs hooks does not change commit/push event identity.
TINYAI_OBS_GIT_HOOK_TOOL=git

# Optional identity defaults. VS Code settings can still provide these.
# TINYAI_OBS_USER_NAME=lyl
# TINYAI_OBS_USER_ID=lyl
# TINYAI_OBS_TEAM=hotel

# Optional per-plugin overrides. Leave commented unless one plugin needs a different collector.
# TINYAI_OBS_COPILOT_COLLECTOR_URL=http://10.161.248.133:18080
# TINYAI_OBS_CLAUDE_COLLECTOR_URL=http://10.161.248.133:18080
# TINYAI_OBS_CODEX_COLLECTOR_URL=http://10.161.248.133:18080
#
# Optional per-plugin offline queues. Defaults are already isolated:
# ~/.tinyai-observability/queue-copilot.jsonl
# ~/.tinyai-observability/queue-claude.jsonl
# ~/.tinyai-observability/queue-codex.jsonl
# TINYAI_OBS_COPILOT_QUEUE=/Users/user/.tinyai-observability/queue-copilot.jsonl
# TINYAI_OBS_CLAUDE_QUEUE=/Users/user/.tinyai-observability/queue-claude.jsonl
# TINYAI_OBS_CODEX_QUEUE=/Users/user/.tinyai-observability/queue-codex.jsonl
