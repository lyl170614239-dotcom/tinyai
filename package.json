{
  "name": "tinyai-observability",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:runtime": "npm --prefix plugin-runtime run build",
    "build:vscode": "npm --prefix plugins/vscode-copilot run compile",
    "sync:runtimes": "node scripts/sync-runtimes.mjs",
    "sync:plugin-metadata": "node scripts/sync-plugin-metadata.mjs",
    "build:plugins": "npm run sync:plugin-metadata && npm run build:runtime && npm run sync:runtimes && npm run build:vscode",
    "configure:vscode": "node plugins/vscode-copilot/scripts/configure.mjs",
    "install:ai-plugins": "bash scripts/install_teammate_ai_plugins.sh",
    "install:claude-plugin": "node scripts/install_claude_observability_plugin.mjs",
    "install:codex-plugin": "node scripts/install_codex_observability_plugin.mjs",
    "typecheck": "npm --prefix plugin-runtime run typecheck && npm --prefix plugins/vscode-copilot run typecheck",
    "test:conversation": "npm run build:runtime && node --test tests/conversation-replay.test.mjs",
    "test:copilot-usage": "npm run build:runtime && node --test tests/copilot-usage-replay.test.mjs",
    "test:minimal-collection": "node --test tests/minimal-collection.test.mjs",
    "test:normalization": "PYTHONPATH=collector-server python3 -m unittest collector-server/tests/test_normalization.py"
  }
}
